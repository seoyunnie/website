{
  "cssVariables.lookupFiles": ["**/*.css", "node_modules/@mantine/core/styles.css"],

  "oxc.configPath": ".oxlintrc.json",
  "oxc.disableNestedConfig": true,
  "oxc.tsConfigPath": "tsconfig.json",
  "oxc.typeAware": true,
  "oxc.unusedDisableDirectives": "warn",

  "prettier.configPath": ".prettierrc.json",
  "prettier.ignorePath": ".prettierignore",

  "[css][html][json][jsonc][markdown][typescript][typescriptreact][yaml]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode"
  }
}
